# Configurações do Servidor
PORT=3000

# Caminho do Banco de Dados SQLite
DATABASE_PATH=./data/app.db

# Segurança e Autenticação
# Altere 'sua_chave_secreta_aqui' para uma string longa e aleatória em produção
JWT_SECRET=sua_chave_secreta_aqui

# Configurações de Upload
UPLOAD_DIR=./uploads/photos

# Integração Industrial (Opcional - para scripts Python/SDKs)
PLC_IP=192.168.0.10
INTELBRAS_DEVICE_IP=192.168.0.100
INTELBRAS_USER=admin
INTELBRAS_PASS=admin123